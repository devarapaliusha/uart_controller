&uart0 { status = "disabled"; }; /* make sure uart2 isn't conflicting */
&adc { status = "disabled"; };
&uart2 {
    status = "okay";
    current-speed = <115200>;
    parity = "none";
    pinctrl-0 = <&uart2_default>;
    pinctrl-1 = <&uart2_sleep>;
    pinctrl-names = "default", "sleep";
};

&pinctrl {
    uart2_default: uart2_default {
        group1 {
             psels = <
                NRF_PSEL(UART_TX, 0, 6)  /* TX = P0.06 */
                NRF_PSEL(UART_RX, 0, 7)  /* RX = P0.07 */
            >;
        };
    };

    uart2_sleep: uart2_sleep {
        group1 {
            psels = <
                NRF_PSEL(UART_TX, 0, 6)  /* TX = P0.06 */
                NRF_PSEL(UART_RX, 0, 7)  /* RX = P0.07 */
            >;
            low-power-enable;
        };
    };
};
