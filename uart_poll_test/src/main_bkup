static const char *candidates[] = {
    "UART_0", "UART_1", "UART_2",
    "UART0", "UART1", "UART2",
    "CDC_ACM_0", "CONSOLE", NULL
};

/* Convert NMEA field ddmm.mmmm (or dddmm.mmmm) and hemisphere -> decimal degrees */
static double nmea_to_deg(const char *field, char hemi)
{
    if (!field || field[0] == '\0') return 0.0;
    double v = atof(field);
    int deg = (int)(v / 100.0);            /* degrees portion */
    double minutes = v - (deg * 100.0);    /* minutes */
    double dec = deg + minutes / 60.0;
    if (hemi == 'S' || hemi == 'W') dec = -dec;
    return dec;
}

/* Parse tokens from CSV-like NMEA line into an array of pointers */
static int tokenize(char *buf, char *fields[], int max_fields)
{
    int n = 0;
    char *tok = strtok(buf, ",");
    while (tok != NULL && n < max_fields) {
        fields[n++] = tok;
        tok = strtok(NULL, ",");
    }
    return n;
}

static bool nmea_check_checksum(const char *s)
{
    if (!s || s[0] != '$') return false;
    const char *p = strchr(s, '*');
    if (!p || (p - s) < 1) return false;
    uint8_t cs = 0;
    for (const char *q = s + 1; q < p; q++) cs ^= (uint8_t)(*q);
    unsigned int rx;
    if (sscanf(p + 1, "%2x", &rx) != 1) return false;
    return cs == (uint8_t)rx;
}


/* Parse RMC (preferred) or GGA (fallback) and print decimal lat/lon + meta */
static void handle_nmea_line(const char *line)
{
    if (!nmea_check_checksum(line)) {
        LOG_DBG("NMEA bad checksum: %s", line);
        return;
    }

    /* Work on a local mutable copy */
    char buf[256];
    strncpy(buf, line, sizeof(buf) - 1);
    buf[sizeof(buf) - 1] = '\0';

    /* Tokenize */
    char *fields[32] = {0};
    int nf = 0;
    char *tok = strtok(buf, ",");
    while (tok && nf < (int)ARRAY_SIZE(fields)) {
        fields[nf++] = tok;
        tok = strtok(NULL, ",");
    }
    if (nf == 0) return;

    const char *type = fields[0];

    /* RMC: $--RMC,hhmmss.ss,A/V,lat,NS,lon,EW,sog,cog,ddmmyy,... */
    if (strstr(type, "RMC") != NULL) {
        if (nf > 6 && fields[2] && fields[2][0] == 'A') {
            const char *time = fields[1];
            const char *lat_f = fields[3];
            const char *lat_h = fields[4];
            const char *lon_f = fields[5];
            const char *lon_h = fields[6];

            double lat = nmea_to_deg(lat_f, lat_h ? lat_h[0] : 'N');
            double lon = nmea_to_deg(lon_f, lon_h ? lon_h[0] : 'E');

            LOG_INF("FIX lat=%.6f lon=%.6f time=%s", lat, lon, time ? time : "?");
            return;
        }
        return;
    }

    /* GGA: $--GGA,hhmmss.ss,lat,NS,lon,EW,fix,num_sat,hdop,alt,... */
    if (strstr(type, "GGA") != NULL) {
        if (nf > 7 && fields[6] && fields[6][0] != '0') {
            const char *time = fields[1];
            const char *lat_f = fields[2];
            const char *lat_h = fields[3];
            const char *lon_f = fields[4];
            const char *lon_h = fields[5];
            const char *nsat = fields[7];

            double lat = nmea_to_deg(lat_f, lat_h ? lat_h[0] : 'N');
            double lon = nmea_to_deg(lon_f, lon_h ? lon_h[0] : 'E');

            LOG_INF("FIX lat=%.6f lon=%.6f time=%s sats=%s", lat, lon, time ? time : "?", nsat ? nsat : "?");
            return;
        }
        return;
    }

    /* ignore other sentences */
    LOG_DBG("NMEA other: %s", line);
}


void main(void)
{
    const struct device *uart;
    const struct device *dev = NULL;
    struct uart_config cfg = {
        .baudrate = 115200,
        .parity = UART_CFG_PARITY_NONE,
        .stop_bits = UART_CFG_STOP_BITS_1,
        .data_bits = UART_CFG_DATA_BITS_8,
        .flow_ctrl = UART_CFG_FLOW_CTRL_NONE,
    };
    printk("APP BOOTED\n");
    /* runtime lookup avoids DT pinctrl issues */

    /*for (int i = 0; candidates[i] != NULL; i++) {
        dev = device_get_binding(candidates[i]);
        LOG_INF("Trying '%s' -> %s", candidates[i], dev ? "FOUND" : "not found");
        if (dev) {
            LOG_INF("Using device: %s", candidates[i]);
            break;
        }
    }

    if (!dev) {
        LOG_ERR("No UART device found from candidates. Check devicetree.");
        return;
    }
    uart = dev;*/
    uart = device_get_binding("UART1");
    if (!uart) {
        LOG_ERR("device_get_binding(\"UART_0\") failed");
        return;
    }

    if (!device_is_ready(uart)) {
        LOG_ERR("UART device not ready");
        return;
    }

    if (uart_configure(uart, &cfg) != 0) {
        LOG_ERR("uart_configure failed");
        return;
    }

    LOG_INF("UART open and configured at %d", cfg.baudrate);
    LOG_DBG("UART open and configured at %d", cfg.baudrate);

    LOG_INF("NMEA reader started on  %d",  cfg.baudrate);

    char line[256];
    int pos = 0;
    uint8_t c;

    while (1) {
        if (uart_poll_in(uart, &c) == 0) {
            if (c == '\r') continue;
            if (c == '\n' || pos >= (int)(sizeof(line)-2)) {
                if (pos > 0) {
                    line[pos] = '\0';
                    handle_nmea_line(line);
                    pos = 0;
                }
            } else {
                line[pos++] = (char)c;
            }
        } else {
            k_msleep(2000);
        }
    }
}
