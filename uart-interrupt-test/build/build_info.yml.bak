cmake:
  board:
    name: 'nrf7002dk'
    path:
     - 'C:/ncs/v3.1.1/zephyr/boards/nordic/nrf7002dk'
    qualifiers: 'nrf5340/cpuapp'
    revision: ''
  images:
   - name: 'uart-interrupt-test'
     source-dir: 'C:/ncs/v3.1.1/application/uart-interrupt-test'
     type: 'MAIN'
  kconfig:
    files:
     - 'C:/ncs/v3.1.1/application/uart-interrupt-test/build/_sysbuild/empty.conf'
     - 'C:/ncs/v3.1.1/application/uart-interrupt-test/build/_sysbuild/empty.conf'
    user-files:
     - 'C:/ncs/v3.1.1/application/uart-interrupt-test/build/_sysbuild/empty.conf'
version: '0.1.0'
west:
  command: 'C:\ncs\toolchains\c1a76fddb2\opt\bin\Scripts\west build --build-dir c:/ncs/v3.1.1/application/uart-interrupt-test/build c:/ncs/v3.1.1/application/uart-interrupt-test --pristine --board nrf7002dk/nrf5340/cpuapp -- -DCONF_FILE=prj.conf -DDTC_OVERLAY_FILE=boards/nrf7002dk_nrf5340_cpuapp.overlay'
  topdir: 'c:\ncs\v3.1.1'
  version: '1.4.0'
