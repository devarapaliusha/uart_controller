/delete-node/ &uart2;

&uart1 {
    status = "okay";
    current-speed = <9600>;
    pinctrl-0 = <&uart1_default>;
    pinctrl-1 = <&uart1_sleep>;
    pinctrl-names = "default", "sleep";
};

&pinctrl {
    uart1_default: uart1_default {
        group1 {
            psels = <
                NRF_PSEL(UART_RX, 0, 6)   /* MAX10 TX → P0.06 */
                NRF_PSEL(UART_TX, 0, 7)   /* MAX10 RX ← P0.07 */
            >;
        };
    };

    uart1_sleep: uart1_sleep {
        group1 {
            psels = <
                NRF_PSEL(UART_RX, 0, 6)
                NRF_PSEL(UART_TX, 0, 7)
            >;
            low-power-enable;
        };
    };
};
